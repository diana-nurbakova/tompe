# ToM-PE Environment Variables
# Copy this file to .env and fill in your values.

# --- MT API Keys ---

# Google Translate API (v2 REST)
GOOGLE_TRANSLATE_API_KEY=

# DeepL API (enable in mt_backends.yaml when available)
DEEPL_AUTH_KEY=

# --- LLM Providers ---

# OpenAI (GPT-4.1 — used for injection and as MT)
OPENAI_API_KEY=

# Anthropic (Claude — used as MT)
ANTHROPIC_API_KEY=

# Ollama (authenticated remote server)
OLLAMA_BASE_URL=https://your-ollama-server.example.com/ollama
OLLAMA_API_KEY=

# Together AI (open-source models)
TOGETHER_API_KEY=

# HuggingFace (for NLLB and other HF models)
HF_TOKEN=

# --- Cloud Providers ---

# AWS (for Amazon Translate, if needed)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
